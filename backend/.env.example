# Sao chép file này thành .env (cùng thư mục) và dán key thật vào.
# Lấy key miễn phí tại: https://aistudio.google.com/apikey
GEMINI_API_KEY=dan_key_cua_ban_vao_day

# CSDL: mặc định SQLite (file algosim.db, không cần cài gì).
# Muốn dùng PostgreSQL: bỏ dấu # dòng dưới, sửa thông tin kết nối,
# và cài driver: .venv\Scripts\pip install psycopg2-binary
# DATABASE_URL=postgresql+psycopg2://postgres:password@localhost:5432/algosim
